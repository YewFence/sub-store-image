TZ=Asia/Shanghai
FRONTEND_PUBLIC_PATH=/
SUB_STORE_FRONTEND_BACKEND_PATH=/backend

# 主服务镜像名称
SUB_STORE_IMAGE=ghcr.io/yewfence/sub-store:latest

# 管理页面入口：建议绑定到宿主机的 Tailscale IP
TS_BIND_IP=
SUB_STORE_ADMIN_HTTP_PORT=38080
SUB_STORE_ADMIN_HTTPS_PORT=38443
# SUB_STORE_ADMIN_SERVER_NAME=sub-store.ts.example.internal

# 镜像内默认就是这些值，通常不用改
# SUB_STORE_DOCKER=true
# SUB_STORE_DATA_BASE_PATH=/app/data
# SUB_STORE_BACKEND_API_HOST=0.0.0.0
# SUB_STORE_BACKEND_API_PORT=3000
# SUB_STORE_BACKEND_MERGE=true
# SUB_STORE_FRONTEND_PATH=/app/frontend/dist

SUB_STORE_BODY_JSON_LIMIT=1mb

# 可选：启动时从远程备份恢复数据
SUB_STORE_DATA_URL=
SUB_STORE_DATA_URL_POST=

# 可选：默认代理，格式如 http://host:port 或 socks5://user:pass@host:port
SUB_STORE_BACKEND_DEFAULT_PROXY=
ALL_PROXY=

# 可选：定时任务
SUB_STORE_BACKEND_SYNC_CRON=
SUB_STORE_PRODUCE_CRON=
SUB_STORE_BACKEND_DOWNLOAD_CRON=
SUB_STORE_BACKEND_UPLOAD_CRON=

# 可选：推送服务
SUB_STORE_PUSH_SERVICE=

# 可选：MMDB 自动更新
SUB_STORE_MMDB_CRON=
SUB_STORE_MMDB_COUNTRY_PATH=
SUB_STORE_MMDB_COUNTRY_URL=
SUB_STORE_MMDB_ASN_PATH=
SUB_STORE_MMDB_ASN_URL=

# 可选：如果要给管理面挂自定义 HTTPS 证书
SUB_STORE_ADMIN_ENABLE_TLS=false
SUB_STORE_ADMIN_TLS_CERT_PATH=/certs/admin.crt
SUB_STORE_ADMIN_TLS_KEY_PATH=/certs/admin.key

# 公网订阅入口配置：只有你需要从公网访问你的订阅时才需要
# 订阅文件在公网暴露的路径
SUB_STORE_FEED_PUBLIC_PATH=/yew-rhizome
# 订阅文件在 sub-store 后端的路径
SUB_STORE_FEED_UPSTREAM_PATH=/backend/api/file/yew-rhizome
# 公网域名名称
SUB_STORE_FEED_SERVER_NAME=sub-feed.example.com
# 校验 token 值
SUB_STORE_FEED_TOKEN=change-me
# Cloudflare Tunnel Token
CLOUDFLARED_TUNNEL_TOKEN=
