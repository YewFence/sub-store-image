map $arg_token $feed_missing_token_log {
    "" 1;
    default 0;
}

log_format feed_missing_token 'feed_missing_token time=$time_iso8601 host=$host uri=$uri '
                              'status=$status remote_addr=$remote_addr '
                              'cf_connecting_ip=$http_cf_connecting_ip x_forwarded_for="$http_x_forwarded_for" '
                              'user_agent="$http_user_agent"';

server {
    listen 8080;
    server_name ${FEED_SERVER_NAME};
    client_max_body_size 1m;
    access_log off;
    # feed routes use $arg_token in proxy_pass, so nginx needs an explicit DNS resolver
    # to resolve Docker service names like sub-store at request time.
    resolver 127.0.0.11 ipv6=off valid=30s;
    resolver_timeout 5s;

    location = /healthz {
        return 200 'ok';
    }

${FEED_LOCATION_BLOCKS}

    location / {
        return 404;
    }
}
