TZ=Asia/Shanghai
SUB_STORE_PORT=3000
FRONTEND_PUBLIC_PATH=/
SUB_STORE_FRONTEND_BACKEND_PATH=/backend

# 镜像内默认就是这些值，通常不用改
# SUB_STORE_DOCKER=true
# SUB_STORE_DATA_BASE_PATH=/app/data
# SUB_STORE_BACKEND_API_HOST=0.0.0.0
# SUB_STORE_BACKEND_API_PORT=3000
# SUB_STORE_BACKEND_MERGE=true
# SUB_STORE_FRONTEND_PATH=/app/frontend/dist

SUB_STORE_BODY_JSON_LIMIT=1mb

# 可选：启动时从远程备份恢复数据
SUB_STORE_DATA_URL=
SUB_STORE_DATA_URL_POST=

# 可选：默认代理，格式如 http://host:port 或 socks5://user:pass@host:port
SUB_STORE_BACKEND_DEFAULT_PROXY=
ALL_PROXY=

# 可选：定时任务
SUB_STORE_BACKEND_SYNC_CRON=
SUB_STORE_PRODUCE_CRON=
SUB_STORE_BACKEND_DOWNLOAD_CRON=
SUB_STORE_BACKEND_UPLOAD_CRON=

# 可选：推送服务
SUB_STORE_PUSH_SERVICE=

# 可选：MMDB 自动更新
SUB_STORE_MMDB_CRON=
SUB_STORE_MMDB_COUNTRY_PATH=
SUB_STORE_MMDB_COUNTRY_URL=
SUB_STORE_MMDB_ASN_PATH=
SUB_STORE_MMDB_ASN_URL=
